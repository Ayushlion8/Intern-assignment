# === Transcription Pipeline Keys ===
# Both Gemini (via Vertex AI) and Chirp 3 use the same GCP credentials.

# GCP project ID (required — used for both Gemini and Chirp 3)
GCP_PROJECT_ID=your-gcp-project-id

# Path to GCP service account credentials JSON (required for local dev)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# Alternatively, paste the entire JSON content as a string (for cloud deployment)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# === Optional overrides ===
# GCP_LOCATION=us-central1
# GEMINI_TRANSCRIBE_MODEL_STRONG=gemini-2.5-flash
# GEMINI_TRANSCRIBE_MODEL_PRO=gemini-2.5-pro
# GEMINI_RPM=15000
# GLOBAL_RPM=120
# CACHE_DIR=cache
